{
  "name": "camera",
  "version": "2.9.0",
  "description": "Professional web application for capturing photos with graphical frames, social sharing, event slideshows, and user profile management",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "db:ensure-indexes": "tsx scripts/run-ensure-indexes.ts",
    "db:verify-uri": "tsx scripts/verify-mongo-uri.ts",
    "env:verify": "tsx scripts/verify-env.ts",
    "vercel:link": "npx vercel@latest link",
    "vercel:env-pull": "npx vercel@latest env pull .env.local --yes"
  },
  "keywords": [
    "photo-frames",
    "camera-capture",
    "image-composition",
    "social-sharing",
    "nextjs",
    "mongodb",
    "oauth2",
    "sso"
  ],
  "author": {
    "name": "Csaba Moldovan",
    "email": "moldovancsaba@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/moldovancsaba/camera.git"
  },
  "homepage": "https://github.com/moldovancsaba/camera",
  "license": "MIT",
  "dependencies": {
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "axios": "^1.7.0",
    "mongodb": "^6.8.0",
    "next": "16.0.10",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "18.x || 20.x || 22.x",
    "npm": ">=8.0.0"
  }
}
