# Copy to `.env` and/or `.env.local`, then fill real values. Never commit filled files.
#
# Rotation (regenerate if ever leaked or committed): MONGODB_URI, IMGBB_API_KEY,
# SSO_CLIENT_SECRET, SESSION_SECRET.

# --- Camera app database (Atlas: cluster hostname is not the database name) ---
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=MyCluster
MONGODB_DB=camera

# Optional pool tuning (Atlas + serverless)
# MONGODB_MAX_POOL_SIZE=10
# MONGODB_MIN_POOL_SIZE=0

# --- SSO OAuth / OIDC ---
SSO_BASE_URL=https://sso.example.com
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=http://localhost:3000/api/auth/callback

# --- imgbb (submissions / frames / logos) ---
IMGBB_API_KEY=

# --- App URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

NODE_ENV=development

# Production: dev-login, migrate, debug/*, test-db, test-frames stay 404 unless true
# ALLOW_DANGEROUS_DEV_ROUTES=false

# Reserved for signed sessions / crypto
SESSION_SECRET=
